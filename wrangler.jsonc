{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "qbank-exam",
  "compatibility_date": "2026-05-31",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      "node_modules",
      ".git",
      ".github",
      "scratch",
      "temp"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
